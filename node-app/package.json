{
  "name": "node-accounting-app",
  "version": "1.0.0",
  "description": "Node.js accounting system modernized from legacy COBOL application",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "test": "jest --coverage --verbose",
    "test:unit": "jest tests/unit --verbose",
    "test:integration": "jest tests/integration --verbose",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "keywords": [
    "accounting",
    "cobol",
    "modernization",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
